{
  "name": "natours",
  "version": "1.0.0",
  "description": "Learning express and mongoDB",
  "license": "ISC",
  "author": "Khaled Sherif",
  "type": "commonjs",
  "targets": {
    "frontend": {
      "context": "browser",
      "outputFormat": "global",
      "distDir": "./public/dist",
      "engines": {
        "browsers": [
          "> 0.5%",
          "last 2 versions",
          "not dead"
        ]
      }
    }
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:prod": "set NODE_ENV=production&& nodemon server.js",
    "debug": "nodemon --inspect server.js",
    "watch:js": "parcel watch ./public/js/index.js --target frontend",
    "build:js": "parcel build ./public/js/index.js --target frontend --no-source-maps"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "core-js": "^3.49.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "html-to-text": "^10.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pug": "^3.0.4",
    "regenerator-runtime": "^0.14.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "stripe": "^22.2.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.35"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "devDependencies": {
    "buffer": "^6.0.3",
    "cross-env": "^10.1.0",
    "parcel": "^2.16.4"
  }
}
